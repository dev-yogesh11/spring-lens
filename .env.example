# Copy this file to .env and fill in your values
# cp .env.example .env

# Database
DB_USERNAME=springlens
DB_PASSWORD=your_secure_db_password

# Redis
REDIS_PASSWORD=your_secure_redis_password

# AI Keys
OPENAI_API_KEY=sk-...
GROQ_AI_API_KEY=gsk_...
COHERE_API_KEY=...

# JWT — must be a strong random string (256-bit minimum)
JWT_SECRET=your_256bit_secret_here
